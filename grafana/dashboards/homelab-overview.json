{
  "title": "Homelab Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "NAS Ping",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-icmp\", instance=\"192.0.2.20\"}"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Box Ping",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-icmp\", instance=\"192.0.2.1\"}"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "NAS Web",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http\"}"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "NAS SMB",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-tcp\"}"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Latence Blackbox",
      "targets": [
        {
          "expr": "probe_duration_seconds"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Raspberry Pi",
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job=\"raspberry-pi\",mode=\"idle\"}[5m])) * 100)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "type": "timeseries",
      "title": "RAM disponible Raspberry Pi",
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"raspberry-pi\"} / node_memory_MemTotal_bytes{job=\"raspberry-pi\"} * 100"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    }
  ]
}
